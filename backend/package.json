{
  "name": "hmherbs-backend",
  "version": "1.0.0",
  "description": "H&M Herbs & Vitamins - Backend API Server",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "test": "jest",
    "migrate": "node scripts/migrate.js",
    "seed": "node scripts/seed.js",
    "match-brands": "node scripts/match-products-to-brands.js",
    "match-categories": "node scripts/match-products-to-categories.js",
    "ensure-images": "node scripts/ensure-product-catalog-images.js",
    "fetch-live-images": "node scripts/fetch-hmherbs-product-images.js",
    "fetch-product-images-json-fast": "node scripts/fetch-hmherbs-product-images.js --json-only",
    "fetch-product-images-try-json-first": "node scripts/fetch-hmherbs-product-images.js --try-json-first",
    "report-image-gaps": "node scripts/report-product-image-gaps.js",
    "report-image-gaps-db": "node scripts/report-product-image-gaps.js --db-only",
    "sync-catalog-images": "node scripts/sync-catalog-primary-images-to-db.js",
    "heal-product-images": "node scripts/heal-product-image-gaps.js",
    "heal-product-images-json": "node scripts/heal-product-image-gaps.js --json-only",
    "catalog-health": "node scripts/sync-catalog-primary-images-to-db.js --dry-run && node scripts/report-product-image-gaps.js",
    "test:nmi-connectivity": "node scripts/test-nmi-connectivity.js",
    "verify:nmi-parse": "node scripts/verify-nmi-gateway-parse.js",
    "set-customer-password": "node scripts/set-customer-password.js"
  },
  "keywords": [
    "herbs",
    "vitamins",
    "supplements",
    "ecommerce",
    "health",
    "wellness"
  ],
  "author": "H&M Herbs & Vitamins",
  "license": "MIT",
  "dependencies": {
    "axios": "^1.6.0",
    "bcrypt": "^5.1.1",
    "cheerio": "^1.0.0-rc.12",
    "compression": "^1.7.4",
    "cors": "^2.8.5",
    "csv-parser": "^3.0.0",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-rate-limit": "^7.1.5",
    "express-validator": "^7.0.1",
    "googleapis": "^129.0.0",
    "helmet": "^7.1.0",
    "jsonwebtoken": "^9.0.2",
    "multer": "^1.4.5-lts.1",
    "mysql2": "^3.6.5",
    "nodemailer": "^7.0.11",
    "puppeteer": "^24.34.0",
    "redis": "^4.6.10",
    "rimraf": "^5.0.5",
    "stripe": "^14.9.0",
    "winston": "^3.11.0",
    "xml2js": "^0.6.2"
  },
  "devDependencies": {
    "jest": "^29.7.0",
    "nodemon": "^3.0.2",
    "supertest": "^7.1.3"
  },
  "engines": {
    "node": ">=16.0.0",
    "npm": ">=8.0.0"
  }
