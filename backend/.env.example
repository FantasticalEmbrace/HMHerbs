# H&M Herbs & Vitamins - Environment Configuration

# Server Configuration
NODE_ENV=development
PORT=3001
FRONTEND_URL=http://localhost:3000
# Public base URL for customer password-reset links (reset-password.html). Defaults to FRONTEND_URL, then http://localhost:PORT.
# STOREFRONT_PUBLIC_URL=https://www.hmherbs.com

# SEO / migration
# Staging only — blocks indexing via X-Robots-Tag and Disallow-all robots.txt. Remove before production launch.
# STAGING_BLOCK_INDEXING=true
# Redirect CSVs at repo root (server loads redirects-301.csv + redirects-legacy-sitemap.csv automatically).
# SEO_REDIRECTS_FILE=redirects-301.csv
# SEO_REDIRECTS_FILES=redirects-301.csv,redirects-legacy-sitemap.csv
# Public storefront URL for sitemaps and order emails (defaults to FRONTEND_URL).
# STOREFRONT_PUBLIC_URL=https://www.hmherbs.com
# Regenerate: npm run seo:generate-sitemap -- --base-url https://hmherbs.com
# Pre-launch checks: npm run seo:verify

# Database Configuration
# Local: MySQL on localhost. Production (Linode): see backend/.env.linode.example
# MySQL must be running locally (Windows: Services app → MySQL, or XAMPP/WAMP "Start MySQL").
# If the app logs ECONNREFUSED, the server cannot reach DB_HOST:port (default 3306).
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your_password_here
DB_NAME=hmherbs
# Linode Managed MySQL only:
# DB_SSL=true
# DB_SSL_CA_PATH=./certs/ca-certificate.crt

# JWT Configuration
# CRITICAL: Generate a strong JWT secret with at least 32 characters
# Use: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=your_super_secret_jwt_key_here_change_in_production

# Redis Configuration (Optional - for caching)
# REDIS_URL=redis://localhost:6379

# Email / SMTP (required for real password-reset emails; optional in dev — link is printed to the server console if unset)
# The app accepts EITHER the SMTP_* names below OR the legacy EMAIL_* names (same values).
#
# Gmail (typical dev setup):
# 1) Google Account → Security → 2-Step Verification ON
# 2) App passwords → create "Mail" → paste the 16-char value as SMTP_PASSWORD (not your normal Gmail password)
#
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=hmherbs1@gmail.com
SMTP_PASSWORD=your_gmail_app_password_here
SMTP_FROM="H&M Herbs <hmherbs1@gmail.com>"
EDSA_NOTIFY_EMAIL=hmherbs1@gmail.com
#
# Legacy aliases (still read by server.js if SMTP_* are empty):
# EMAIL_HOST=smtp.gmail.com
# EMAIL_PORT=587
# EMAIL_USER=your_email@gmail.com
# EMAIL_PASS=your_gmail_app_password_here
# EMAIL_FROM=your_email@gmail.com

# Payment Gateway (Stripe)
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key_here
STRIPE_PUBLISHABLE_KEY=pk_test_your_stripe_publishable_key_here

# Durango / NMI (Collect.js + Direct Post API — Durango is white-labeled NMI)
# Durango portal login (DURANGO_USERNAME / DURANGO_PASSWORD) is for the merchant UI only.
# The app uses NMI env names below; Direct Post uses security_key, not username/password.
#
# Public Collect.js tokenization key (browser-safe). For sandbox without Durango-specific keys:
# NMI_PUBLIC_TOKENIZATION_KEY=56w49b-7Z97G6-4M962m-98A77V
NMI_PUBLIC_TOKENIZATION_KEY=
# Direct Post security_key from Durango/NMI portal (Settings → API / Security Keys).
# NOT the Collect.js public key. Aliases: NMI_API_KEY, DURANGO_API_KEY
NMI_PRIVATE_API_KEY=
# Legacy aliases (still supported): NMI_PUBLIC_KEY, NMI_PRIVATE_KEY
#
# Sandbox (dummy / test merchant):
NMI_SANDBOX=1
NMI_COLLECT_JS_URL=https://sandbox.nmi.com/token/Collect.js
NMI_API_URL=https://sandbox.nmi.com/api/transact.php
#
# Production:
# NMI_SANDBOX=0
# NMI_COLLECT_JS_URL=https://secure.nmi.com/token/Collect.js
# NMI_API_URL=https://secure.nmi.com/api/transact.php
#
# Test card (sandbox): 4000 0000 0000 2701
# Skip server-side tokenization-key probe if needed:
# NMI_SKIP_TOKENIZATION_PREFLIGHT=1
# Disable Apple Pay / Google Pay in Collect.js (recommended for sandbox until wallets are configured):
# NMI_DISABLE_WALLETS=1

# File Upload Configuration
UPLOAD_DIR=uploads
MAX_FILE_SIZE=5242880

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# EDSA Service Configuration
EDSA_SERVICE_ENABLED=true
EDSA_SERVICE_PRICE=75.00

# Shipping Configuration
FREE_SHIPPING_THRESHOLD=25.00
DEFAULT_SHIPPING_COST=5.99

# Tax Configuration
DEFAULT_TAX_RATE=0.08
# Daily webstore + POS tax sync into tax_entries (23:50 local). Requires tax_entries tables.
TAX_LEDGER_SYNC_ENABLED=true
# Monthly Excel tax report emailed to accountant on the 1st (full previous calendar month). Requires SMTP_*.
# Sends at/after 8:00 AM local; retries same day if SMTP fails; syncs every day in that month first.
TAX_ACCOUNTANT_REPORT_ENABLED=true
TAX_ACCOUNTANT_EMAIL=wandaforto@aol.com
# TAX_ACCOUNTANT_REPORT_HOUR=8
# TAX_ACCOUNTANT_REPORT_MINUTE=0

# Mailchimp signup page (default if not set in admin Marketing → Newsletter signup)
MAILCHIMP_SIGNUP_LANDING_URL=https://mailchi.mp/7cd1b02d1358/subscribe-to-newsletter
# Optional dev-only API (not used by the site UI; omit if Mailchimp is managed elsewhere)
# MAILCHIMP_API_KEY=
# MAILCHIMP_AUDIENCE_ID=
# MAILCHIMP_SERVER_PREFIX=us16
# MAILCHIMP_FROM_NAME=H&M Herbs & Vitamins
# MAILCHIMP_REPLY_TO=

# Google Business Profile (hours sync; token stored in DB after admin connect)
# Same OAuth client also powers "Continue with Google" for customers and admin staff login.
# In Google Cloud Console → APIs & Services → Credentials → your OAuth client → Authorized redirect URIs, add:
#   http://127.0.0.1:3001/api/auth/google/callback
#   http://127.0.0.1:3001/api/admin/auth/google/callback
# Optional (if you browse via localhost instead of 127.0.0.1):
#   http://localhost:3001/api/auth/google/callback
#   http://localhost:3001/api/admin/auth/google/callback
# Production (replace with your live domain):
#   https://www.hmherbs.com/api/auth/google/callback
#   https://www.hmherbs.com/api/admin/auth/google/callback
# Optional overrides (must match Console exactly):
# CUSTOMER_GOOGLE_REDIRECT_URI=http://127.0.0.1:3001/api/auth/google/callback
# ADMIN_GOOGLE_REDIRECT_URI=http://127.0.0.1:3001/api/admin/auth/google/callback
GBP_CLIENT_ID=
GBP_CLIENT_SECRET=
GBP_REFRESH_TOKEN=
GBP_LOCATION_NAME=
GBP_REDIRECT_URI=
ADMIN_APP_URL=http://localhost:3001/admin.html

# Google Calendar (EDSA). Uses GBP_* creds when GCAL_* omitted. Service account: config/google-credentials.json
GCAL_CLIENT_ID=
GCAL_CLIENT_SECRET=
GCAL_REDIRECT_URI=
GCAL_REFRESH_TOKEN=
GOOGLE_CALENDAR_ID=primary
GOOGLE_CREDENTIALS_PATH=
