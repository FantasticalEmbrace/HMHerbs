# HM Herbs — Linode / Akamai (temp domain → production cutover)
# Copy to backend/.env on your Linode (never commit real .env)
#
# Fast path: from your dev machine with a working backend/.env:
#   .\deploy\sync-linode-env.ps1
# Then verify:
#   ssh root@YOUR_LINODE 'bash /var/www/hmherbs/deploy/verify-linode-features.sh'

NODE_ENV=production
PORT=3001

# Public URL — Miami NodeBalancer sslip until hmherbs.com DNS points here
FRONTEND_URL=https://172-238-208-164.sslip.io
STOREFRONT_PUBLIC_URL=https://172-238-208-164.sslip.io
PRODUCTION_DOMAIN=172-238-208-164.sslip.io
ADMIN_APP_URL=https://172-238-208-164.sslip.io/admin.html

# Block search indexing until production launch (remove or set false after domain cutover)
STAGING_BLOCK_INDEXING=true

# Linode Managed MySQL (Cloud Manager → Databases → Connection Details)
DB_HOST=lin-xxxxx-xxxx.servers.linodedb.net
DB_PORT=3306
DB_USER=akmadmin
DB_PASSWORD=your_managed_db_password
DB_NAME=hmherbs
DB_SSL=true
DB_SSL_CA_PATH=./certs/ca-certificate.crt

JWT_SECRET=replace_with_new_random_hex_secret

# --- Email (password reset, orders, EDSA) ---
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=hmherbs1@gmail.com
SMTP_PASSWORD=your_16_char_google_app_password
SMTP_FROM="H&M Herbs <hmherbs1@gmail.com>"
EDSA_NOTIFY_EMAIL=hmherbs1@gmail.com

# --- Checkout payments (NMI / Durango) — use sandbox until go-live ---
NMI_SANDBOX=1
NMI_PUBLIC_TOKENIZATION_KEY=
NMI_PRIVATE_API_KEY=
NMI_COLLECT_JS_URL=https://sandbox.nmi.com/token/Collect.js
NMI_API_URL=https://sandbox.nmi.com/api/transact.php
NMI_DISABLE_WALLETS=1
NMI_SKIP_TOKENIZATION_PREFLIGHT=1

# --- Google OAuth (sign-in + Business Profile + Calendar) ---
# Register ALL redirect URIs in Google Cloud Console — see deploy/GOOGLE_OAUTH_REDIRECT_URIS.md
GBP_CLIENT_ID=
GBP_CLIENT_SECRET=

# Miami Linode (active now)
CUSTOMER_GOOGLE_REDIRECT_URI=https://172-238-208-164.sslip.io/api/auth/google/callback
ADMIN_GOOGLE_REDIRECT_URI=https://172-238-208-164.sslip.io/api/admin/auth/google/callback
GBP_REDIRECT_URI=https://172-238-208-164.sslip.io/api/admin/settings/google-business/callback
GCAL_REDIRECT_URI=https://172-238-208-164.sslip.io/api/admin/settings/google-calendar/callback

# Production (add these URIs in Google Console before cutover; then sync-linode-env.ps1 -TempDomain www.hmherbs.com)
# CUSTOMER_GOOGLE_REDIRECT_URI=https://www.hmherbs.com/api/auth/google/callback
# ADMIN_GOOGLE_REDIRECT_URI=https://www.hmherbs.com/api/admin/auth/google/callback
# GBP_REDIRECT_URI=https://www.hmherbs.com/api/admin/settings/google-business/callback
# GCAL_REDIRECT_URI=https://www.hmherbs.com/api/admin/settings/google-calendar/callback

# --- In-store POS ---
POS_DEVICE_API_KEY=
POS_STORE_NAME=H&M Herbs & Vitamins
POS_ALLOWED_ORIGINS=https://172-238-208-164.sslip.io,http://localhost:8080
POS_NMI_SANDBOX=1
POS_NMI_PUBLIC_TOKENIZATION_KEY=
POS_NMI_PRIVATE_API_KEY=
POS_NMI_COLLECT_JS_URL=https://sandbox.nmi.com/token/Collect.js
POS_NMI_API_URL=https://sandbox.nmi.com/api/transact.php

# --- Shipping (optional — flat rates work without Shippo) ---
SHIPPO_API_TOKEN=
SHIPPO_TEST_MODE=true
SHIPPO_CARRIERS=usps,ups,fedex
SHIPPO_FROM_NAME=H&M Herbs & Vitamins
SHIPPO_FROM_COMPANY=H&M Herbs & Vitamins
SHIPPO_FROM_STREET1=1140 Battlefield Pkwy
SHIPPO_FROM_CITY=Fort Oglethorpe
SHIPPO_FROM_STATE=GA
SHIPPO_FROM_ZIP=30742
SHIPPO_FROM_COUNTRY=US
SHIPPO_FROM_PHONE=7068619454
SHIPPO_FROM_EMAIL=hmherbs1@gmail.com

# --- Tax / accountant reports ---
TAX_LEDGER_SYNC_ENABLED=true
TAX_ACCOUNTANT_REPORT_ENABLED=true
TAX_ACCOUNTANT_EMAIL=

# --- AI network setup assistant (admin) ---
OPENAI_API_KEY=

# --- Mailchimp ---
MAILCHIMP_SIGNUP_LANDING_URL=https://mailchi.mp/7cd1b02d1358/subscribe-to-newsletter
