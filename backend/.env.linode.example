# HM Herbs — Linode / Akamai production / staging
# Copy to backend/.env on your Linode (never commit real .env)

NODE_ENV=production
PORT=3001

# Public URL (no trailing slash)
FRONTEND_URL=https://your-domain.com
STOREFRONT_PUBLIC_URL=https://your-domain.com
PRODUCTION_DOMAIN=your-domain.com

# Linode Managed MySQL (Cloud Manager → Databases → Connection Details)
DB_HOST=lin-xxxxx-xxxx.servers.linodedb.net
DB_PORT=3306
DB_USER=akmadmin
DB_PASSWORD=your_managed_db_password
DB_NAME=hmherbs
# Required for Linode Managed MySQL (SSL). Auto-enabled if DB_HOST ends with linodedb.net.
DB_SSL=true
# Download CA from Cloud Manager → Connection Details → save on server:
DB_SSL_CA_PATH=./certs/ca-certificate.crt

# New secret for production:
# node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=replace_with_new_random_hex_secret

# Staging subdomain only — block search indexing
# STAGING_BLOCK_INDEXING=true

# Payments — sandbox on staging
NMI_SANDBOX=1
NMI_PUBLIC_TOKENIZATION_KEY=
NMI_PRIVATE_API_KEY=
NMI_COLLECT_JS_URL=https://sandbox.nmi.com/token/Collect.js
NMI_API_URL=https://sandbox.nmi.com/api/transact.php

# Required for EDSA appointment emails, order confirmations, and password reset
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=hmherbs1@gmail.com
SMTP_PASSWORD=your_16_char_google_app_password
SMTP_FROM="H&M Herbs <hmherbs1@gmail.com>"
EDSA_NOTIFY_EMAIL=hmherbs1@gmail.com
# Legacy aliases (optional if SMTP_* above are set)
# EMAIL_HOST=smtp.gmail.com
# EMAIL_PORT=587
# EMAIL_USER=hmherbs1@gmail.com
# EMAIL_PASS=your_16_char_google_app_password
# STOREFRONT_PUBLIC_URL must match your live site (used in email links)
