# HM Herbs — DigitalOcean production / staging
# Copy to backend/.env on your Droplet (never commit real .env)

NODE_ENV=production
PORT=3001

# Public URL (no trailing slash)
FRONTEND_URL=https://your-domain.com
STOREFRONT_PUBLIC_URL=https://your-domain.com
PRODUCTION_DOMAIN=your-domain.com

# DigitalOcean Managed MySQL (from cluster → Connection Details)
DB_HOST=db-mysql-nyc3-xxxxx.db.ondigitalocean.com
DB_PORT=25060
DB_USER=doadmin
DB_PASSWORD=your_managed_db_password
DB_NAME=hmherbs
DB_SSL=true
# Download CA from DO panel → save on server, e.g. backend/certs/ca-certificate.crt
DB_SSL_CA_PATH=./certs/ca-certificate.crt

# New secret for production:
# node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=replace_with_new_random_hex_secret

# Staging subdomain only — block search indexing
# STAGING_BLOCK_INDEXING=true

# Payments — sandbox on staging
NMI_SANDBOX=1
NMI_PUBLIC_TOKENIZATION_KEY=
NMI_PRIVATE_API_KEY=
NMI_COLLECT_JS_URL=https://sandbox.nmi.com/token/Collect.js
NMI_API_URL=https://sandbox.nmi.com/api/transact.php

# Optional SMTP for password-reset emails
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASSWORD=
